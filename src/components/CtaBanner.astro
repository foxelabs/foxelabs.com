---
import EmailForm from './EmailForm.astro';
---
<section class="py-16 md:py-20" data-reveal>
  <div class="container-x">
    <div
      id="waitlist"
      class="rounded-xl p-8 md:p-10 flex flex-col md:flex-row md:items-center md:justify-between gap-8"
      style="background: var(--color-surface); border: 1px solid var(--color-border);"
    >
      <div class="md:max-w-md">
        <h3 class="font-display font-semibold text-2xl mb-2" style="letter-spacing: -0.5px;">
          Be first when we launch
        </h3>
        <p class="text-sm" style="color: var(--color-muted);">
          Join the waitlist — early access, launch pricing, and product updates.
        </p>
      </div>
      <div class="md:flex-shrink-0">
        <EmailForm id="cta-form" />
      </div>
    </div>
  </div>
</section>
