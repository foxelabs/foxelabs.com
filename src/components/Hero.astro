---
import EmailForm from './EmailForm.astro';
---
<section class="relative overflow-hidden" data-reveal>
  <svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true">
    <defs>
      <pattern id="dotgrid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="1" fill="#1F2937" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#dotgrid)" />
  </svg>

  <div class="container-x relative py-20 md:py-28">
    <div class="grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7">
        <p class="font-mono text-[11px] mb-6" style="color: var(--color-gold); letter-spacing: 2px;">
          // algo trading tools · est. 2025
        </p>
        <h1
          class="font-display font-bold text-[36px] md:text-[52px] leading-[1.05] mb-6"
          style="letter-spacing: -1px;"
        >
          Built for traders who run on <span style="color: var(--color-gold);">edge</span>
        </h1>
        <p class="text-[15px] mb-8 max-w-[440px]" style="color: var(--color-muted);">
          Expert advisors, a trading journal, and precision tools — engineered for prop firm traders and serious algo traders.
        </p>

        <EmailForm id="hero-form" />

        <p class="mt-3 text-[11px]" style="color: var(--color-hint);">
          No spam. First to know when products ship.
        </p>
      </div>

      <div class="hidden md:flex md:col-span-5 justify-end">
        <svg
          width="220" height="130" viewBox="0 0 220 130"
          style="opacity: 0.45;"
          aria-hidden="true"
        >
          <g stroke="#1F2937" stroke-width="0.5">
            <line x1="0" y1="20"  x2="220" y2="20" />
            <line x1="0" y1="50"  x2="220" y2="50" />
            <line x1="0" y1="80"  x2="220" y2="80" />
            <line x1="0" y1="110" x2="220" y2="110" />
          </g>

          <!-- wicks -->
          <g stroke-width="1">
            <line x1="12"  y1="40" x2="12"  y2="92"  stroke="#10B981" />
            <line x1="30"  y1="32" x2="30"  y2="78"  stroke="#EF4444" />
            <line x1="48"  y1="46" x2="48"  y2="96"  stroke="#10B981" />
            <line x1="66"  y1="38" x2="66"  y2="86"  stroke="#10B981" />
            <line x1="84"  y1="30" x2="84"  y2="74"  stroke="#EF4444" />
            <line x1="102" y1="36" x2="102" y2="82"  stroke="#10B981" />
            <line x1="120" y1="24" x2="120" y2="70"  stroke="#10B981" />
            <line x1="138" y1="20" x2="138" y2="60"  stroke="#EF4444" />
            <line x1="156" y1="14" x2="156" y2="54"  stroke="#10B981" />
            <line x1="174" y1="10" x2="174" y2="48"  stroke="#10B981" />
            <line x1="192" y1="18" x2="192" y2="44"  stroke="#EF4444" />
            <line x1="210" y1="6"  x2="210" y2="36"  stroke="#10B981" />
          </g>

          <!-- bodies -->
          <g>
            <rect x="8"   y="60" width="8" height="22" fill="#10B981" />
            <rect x="26"  y="44" width="8" height="22" fill="#EF4444" />
            <rect x="44"  y="62" width="8" height="24" fill="#10B981" />
            <rect x="62"  y="52" width="8" height="22" fill="#10B981" />
            <rect x="80"  y="42" width="8" height="24" fill="#EF4444" />
            <rect x="98"  y="50" width="8" height="22" fill="#10B981" />
            <rect x="116" y="38" width="8" height="22" fill="#10B981" />
            <rect x="134" y="32" width="8" height="20" fill="#EF4444" />
            <rect x="152" y="24" width="8" height="22" fill="#10B981" />
            <rect x="170" y="20" width="8" height="20" fill="#10B981" />
            <rect x="188" y="28" width="8" height="12" fill="#EF4444" />
            <rect x="206" y="14" width="8" height="18" fill="#10B981" />
          </g>

          <line
            class="trend-line"
            x1="10" y1="100" x2="216" y2="20"
            stroke="#F59E0B" stroke-width="1.2" stroke-dasharray="4 3" fill="none"
          />

          <text x="6" y="126" font-family="JetBrains Mono, monospace" font-size="8" fill="#6B7280">
            XAUUSD · M15
          </text>
        </svg>
      </div>
    </div>
  </div>
</section>
