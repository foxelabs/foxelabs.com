---
const products = [
  {
    title: 'Expert Advisors',
    description:
      'Battle-tested MQL5 EAs for XAUUSD and prop firm accounts. ICT/SMC-based strategies with rigorous risk controls.',
    badge: 'Waitlist open',
    iconBg: '#451A03',
    iconColor: '#F59E0B',
    badgeBg: '#451A03',
    badgeColor: '#F59E0B',
    border: '0.5px solid #92400E',
    featured: true,
    icon: 'bot',
  },
  {
    title: 'TickerLog',
    description:
      'A universal trading journal that syncs with your broker, analyzes your patterns, and helps you trade better — coming soon.',
    badge: 'Coming soon',
    iconBg: '#0F1D3A',
    iconColor: '#3B82F6',
    badgeBg: 'var(--color-surface)',
    badgeColor: 'var(--color-muted)',
    border: '0.5px solid var(--color-border)',
    icon: 'book',
  },
  {
    title: 'Trading Tools',
    description:
      'Indicators, dashboards, and utilities for TradingView Pine Script and MT5. Built for precision.',
    badge: 'Coming soon',
    iconBg: '#0D2318',
    iconColor: '#10B981',
    badgeBg: 'var(--color-surface)',
    badgeColor: 'var(--color-muted)',
    border: '0.5px solid var(--color-border)',
    icon: 'chart',
  },
];
---
<section id="products" class="py-20 md:py-28" data-reveal>
  <div class="container-x">
    <p class="font-mono text-[10px] mb-10" style="color: var(--color-hint); letter-spacing: 2px;">
      — what we're building
    </p>

    <div class="grid md:grid-cols-3 gap-5">
      {products.map((p) => (
        <article
          class="p-6 rounded-xl flex flex-col"
          style={`background: var(--color-surface); border: ${p.border};`}
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-5"
            style={`background: ${p.iconBg};`}
          >
            {p.icon === 'bot' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={p.iconColor} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="7" width="16" height="12" rx="2" />
                <line x1="12" y1="3" x2="12" y2="7" />
                <circle cx="12" cy="3" r="1" fill={p.iconColor} />
                <circle cx="9" cy="13" r="1.2" fill={p.iconColor} />
                <circle cx="15" cy="13" r="1.2" fill={p.iconColor} />
                <line x1="9" y1="17" x2="15" y2="17" />
              </svg>
            )}
            {p.icon === 'book' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={p.iconColor} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h11a3 3 0 0 1 3 3v13H7a3 3 0 0 1-3-3z" />
                <line x1="8" y1="9" x2="14" y2="9" />
                <line x1="8" y1="13" x2="14" y2="13" />
              </svg>
            )}
            {p.icon === 'chart' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={p.iconColor} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <line x1="4" y1="20" x2="20" y2="20" />
                <rect x="6" y="12" width="3" height="6" />
                <rect x="11" y="8" width="3" height="10" />
                <rect x="16" y="5" width="3" height="13" />
              </svg>
            )}
          </div>

          <h3 class="font-display font-semibold text-lg mb-2" style="letter-spacing: -0.5px;">
            {p.title}
          </h3>
          <p class="text-sm mb-6 flex-1" style="color: var(--color-muted);">
            {p.description}
          </p>

          <span
            class="self-start font-mono text-[10px] px-2 py-1 rounded"
            style={`background: ${p.badgeBg}; color: ${p.badgeColor}; letter-spacing: 1px;`}
          >
            {p.badge}
          </span>
        </article>
      ))}
    </div>
  </div>
</section>
